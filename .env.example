# Banco de dados (Postgres local)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crud_app
POSTGRES_PORT=5432

# Conexões de aplicação
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/crud_app
API_URL=http://localhost:8000/v1

# Analytics/Orquestração (opcional)
ANALYTICS_DIR=../analytics
